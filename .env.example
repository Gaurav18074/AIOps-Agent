# === LLM Provider ===
OPENAI_API_KEY=sk-your-key-here
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# === Database ===
DATABASE_URL=postgresql+psycopg://aiops:aiops@db:5432/aiops

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === App ===
LOG_LEVEL=INFO
DEDUP_TTL_SECONDS=300

# === Notifications (optional) ===
SLACK_WEBHOOK_URL=

# === Server ===
API_HOST=0.0.0.0
API_PORT=8000
